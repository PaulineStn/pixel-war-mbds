PORT=3000
# Option A (recommended): full URI
MONGODB_URI=mongodb://pixel_admin:pixel_admin_pwd@127.0.0.1:27017/pixel-war?authSource=admin

# Option B: separate host/db/credentials (used only if MONGODB_URI is empty)
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DB=pixel-war
MONGODB_USER=pixel_admin
MONGODB_PASSWORD=pixel_admin_pwd

# One or multiple origins separated by commas
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change-me-in-production
# jwt secret a generer avec openssl rand -base64 32
NODE_ENV=development